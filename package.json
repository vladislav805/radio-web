{
	"name": "@vladislav805/online-radio",
	"private": true,
	"version": "8.0.0",
	"scripts": {
		"dev": "node src/build/dev.mjs",
		"build:server": "node src/build/server/build.mjs",
		"build:server:production": "NODE_ENV=production npm run build:server",
		"build:client": "node src/build/client/build.mjs",
		"build:client:production": "NODE_ENV=production npm run build:client",
		"build": "run-p \"build:client\" \"build:server\"",
		"build:production": "run-p \"build:client:production\" \"build:server:production\"",
		"test": "jest",
		"typechecking": "tsc --noEmit"
	},
	"dependencies": {
		"@bem-react/classname": "1.7.0",
		"body-parser": "2.2.0",
		"classnames": "2.5.1",
		"express": "5.1.0",
		"hls.js": "1.6.7",
		"mysql2": "3.14.2",
		"react": "19.1.0",
		"react-dom": "19.1.0"
	},
	"devDependencies": {
		"@types/express": "5.0.3",
		"@types/jest": "30.0.0",
		"@types/node": "22.15.18",
		"@types/react": "19.1.8",
		"@types/react-dom": "19.1.6",
		"@veluga/esbuild-restart-on-rebuild": "0.0.2",
		"css-loader": "7.1.2",
		"dotenv": "17.2.0",
		"esbuild": "0.25.8",
		"html-webpack-plugin": "5.6.3",
		"jest": "30.0.4",
		"mini-css-extract-plugin": "2.9.2",
		"npm-run-all": "4.1.5",
		"postcss": "8.5.6",
		"postcss-calc": "10.1.1",
		"postcss-load-config": "6.0.1",
		"postcss-loader": "8.1.1",
		"postcss-media-minmax": "5.0.0",
		"postcss-nesting": "13.0.2",
		"style-loader": "4.0.0",
		"swc-loader": "0.2.6",
		"terser-webpack-plugin": "5.3.14",
		"ts-jest": "29.4.0",
		"typescript": "5.8.3",
		"webpack": "5.100.2"
	},
	"author": {
